<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="TextBlock.title">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource LanTalkMutedTextBrush}"/>
    </Style>

    <Style Selector="Button">
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource LanTalkBlueBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.primary:pointerover">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="Button.primary:pressed">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style Selector="Button.icon">
        <Setter Property="Width" Value="38"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="CornerRadius" Value="19"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource LanTalkSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LanTalkBorderBrush}"/>
    </Style>

    <Style Selector="TextBox.search">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="BorderBrush" Value="{StaticResource LanTalkBorderBrush}"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource LanTalkSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LanTalkBorderBrush}"/>
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{StaticResource LanTalkSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LanTalkBorderBrush}"/>
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource LanTalkTextBrush}"/>
    </Style>
</Styles>
